---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import CtaSection from '../components/CtaSection.astro';
import SectionHeader from '../components/SectionHeader.astro';

const featuredEvent = {
  title: 'XIV Encontro Regulus de Astrologia',
  date: '16 e 17 de Agosto de 2025',
  location: 'São Paulo, SP',
  description: 'O maior evento de astrologia do Brasil está de volta! Dois dias intensos de palestras, workshops e networking com os melhores astrólogos do país e convidados internacionais.',
  highlights: [
    'Palestras com renomados astrólogos nacionais e internacionais',
    'Workshops práticos e interativos',
    'Networking com profissionais e estudantes de astrologia',
    'Livraria especializada com lançamentos exclusivos',
  ],
};

const pastEvents = [
  { number: 'XIII', year: '2024', title: 'XIII Encontro Regulus de Astrologia', online: true },
  { number: 'XII', year: '2023', title: 'XII Encontro Regulus de Astrologia', online: true },
  { number: 'XI', year: '2022', title: 'XI Encontro Regulus de Astrologia', online: true },
  { number: 'X', year: '2021', title: 'X Encontro Regulus de Astrologia', online: true },
  { number: 'IX', year: '2020', title: 'IX Encontro Regulus de Astrologia', online: true },
  { number: 'VIII', year: '2019', title: 'VIII Encontro Regulus de Astrologia', online: false },
  { number: 'VII', year: '2018', title: 'VII Encontro Regulus de Astrologia', online: false },
  { number: 'VI', year: '2017', title: 'VI Encontro Regulus de Astrologia', online: false },
  { number: 'V', year: '2016', title: 'V Encontro Regulus de Astrologia', online: false },
  { number: 'IV', year: '2015', title: 'IV Encontro Regulus de Astrologia', online: false },
  { number: 'III', year: '2014', title: 'III Encontro Regulus de Astrologia', online: false },
  { number: 'II', year: '2013', title: 'II Encontro Regulus de Astrologia', online: false },
  { number: 'I', year: '2012', title: 'I Encontro Regulus de Astrologia', online: false },
];
---

<BaseLayout title="Encontros" description="Encontros Regulus de Astrologia - O maior evento de astrologia do Brasil. Palestras, workshops e networking com os melhores astrólogos.">
  <Header currentPage="/encontros" />
  
  <main>
    <HeroSection
      title="Encontros Regulus de Astrologia"
      subtitle="Desde 2012, reunimos a comunidade astrológica brasileira em um evento único, promovendo conhecimento, troca de experiências e celebração da arte celeste."
      badge="Eventos"
    />

    <!-- Featured Event Section -->
    <section class="section featured-event">
      <div class="container">
        <div class="featured-content">
          <div class="featured-header">
            <span class="event-badge">Próximo Evento</span>
            <h2>{featuredEvent.title}</h2>
            <div class="event-meta">
              <span class="event-date">{featuredEvent.date}</span>
              <span class="separator">•</span>
              <span class="event-location">{featuredEvent.location}</span>
            </div>
          </div>
          
          <div class="featured-body">
            <p class="event-description">{featuredEvent.description}</p>
            
            <div class="event-highlights">
              <h3>O que você vai encontrar:</h3>
              <ul>
                {featuredEvent.highlights.map((highlight) => (
                  <li>
                    <span class="highlight-icon">★</span>
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          
          <div class="featured-footer">
            <a href="/contato" class="btn-primary">Inscreva-se no XIV Encontro</a>
            <a href="https://youtube.com/@astrologiaregulus" target="_blank" rel="noopener noreferrer" class="btn-secondary">
              Edições Online no YouTube
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- About the Event Section -->
    <section class="section about-event">
      <div class="container">
        <div class="about-grid">
          <div class="about-text">
            <h2>O Maior Evento de Astrologia do Brasil</h2>
            <p class="lead">
              Os Encontros Regulus de Astrologia são uma tradição que começou em 2012 e se consolidou 
              como o principal evento do calendário astrológico brasileiro.
            </p>
            <p>
              Durante dois dias, astrólogos profissionais, estudantes e entusiastas se reúnem para 
              assistir palestras de renomados mestres, participar de workshops práticos e trocar 
              experiências com colegas de todo o Brasil.
            </p>
            <p>
              Nosso evento também conta com uma livraria especializada, oferecendo títulos exclusivos 
              e lançamentos que não são encontrados em outros lugares.
            </p>
          </div>
          <div class="about-stats">
            <div class="stat-card">
              <span class="stat-number">13</span>
              <span class="stat-label">Edições Realizadas</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">13+</span>
              <span class="stat-label">Anos de Tradição</span>
            </div>
            <div class="stat-card">
              <span class="stat-number">100+</span>
              <span class="stat-label">Palestras Ministradas</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Past Events Section -->
    <section class="section past-events">
      <div class="container">
        <SectionHeader
          title="Edições Anteriores"
          subtitle="Confira a trajetória dos Encontros Regulus de Astrologia ao longo dos anos. As gravações das edições realizadas a partir de 2020 estão disponíveis em nosso canal no YouTube."
          centered
        />
        
        <div class="timeline">
          {pastEvents.map((event) => (
            <div class={`timeline-item${event.online ? ' timeline-item--online' : ''}`}>
              <div class="timeline-marker">
                <span class="event-number">{event.number}</span>
              </div>
              <div class="timeline-content">
                <div class="timeline-year-row">
                  <span class="timeline-year">{event.year}</span>
                  {event.online && <span class="badge-online">Online</span>}
                </div>
                <h4 class="timeline-title">{event.title}</h4>
              </div>
            </div>
          ))}
        </div>

        <p class="timeline-note">
          ★ A partir da edição de 2020, os Encontros passaram a ser realizados online e estão disponíveis no YouTube. As edições anteriores não estão disponíveis para acesso.
        </p>
        
        <div class="youtube-cta text-center">
          <div class="youtube-card">
            <div class="youtube-icon">▶</div>
            <h3>Assista às Gravações no YouTube</h3>
            <p>
              As edições realizadas a partir de 2020 estão disponíveis em nosso canal oficial no YouTube. 
              Inscreva-se e não perca nenhum conteúdo!
            </p>
            <a 
              href="https://youtube.com/@astrologiaregulus" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="btn-primary"
            >
              Acessar Canal no YouTube
            </a>
          </div>
        </div>
      </div>
    </section>

    <CtaSection
      title="Participe do Próximo Encontro"
      subtitle="Não perca a oportunidade de fazer parte do XIV Encontro Regulus de Astrologia. Garanta sua vaga e viva essa experiência única!"
      primaryBtn={{ label: 'Quero Me Inscrever', href: '/contato' }}
      secondaryBtn={{ label: 'Conhecer os Cursos', href: '/cursos' }}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* (hero styles moved to HeroSection.astro) */

  /* Featured Event Section */
  .featured-event {
    background-color: var(--color-tertiary);
    position: relative;
  }

  .featured-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .featured-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .event-badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-tertiary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
  }

  .featured-header h2 {
    font-size: var(--font-size-h2);
    margin-bottom: var(--spacing-sm);
  }

  .event-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    font-size: var(--font-size-lg);
  }

  .event-date {
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .separator {
    color: var(--color-accent);
  }

  .event-location {
    color: var(--color-text);
  }

  .featured-body {
    margin-bottom: var(--spacing-lg);
  }

  .event-description {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .event-highlights {
    background-color: var(--color-surface);
    padding: var(--spacing-lg);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-accent);
  }

  .event-highlights h3 {
    font-size: var(--font-size-h4);
    margin-bottom: var(--spacing-sm);
  }

  .event-highlights ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .event-highlights li {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
    font-size: var(--font-size-base);
  }

  .highlight-icon {
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .featured-footer {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* About Event Section */
  .about-event {
    background-color: var(--color-surface);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .about-text h2 {
    margin-bottom: var(--spacing-md);
    position: relative;
    display: inline-block;
  }

  .about-text h2::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--spacing-xs));
    left: 0;
    width: 60px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .about-text .lead {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }

  .about-text p {
    margin-bottom: var(--spacing-sm);
    line-height: var(--line-height-relaxed);
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .stat-card {
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-black);
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--spacing-xs);
  }

  .stat-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
  }

  /* Past Events Section */
  .past-events {
    background-color: var(--color-tertiary);
  }

  /* (section-title/subtitle styles moved to SectionHeader.astro) */

  /* Timeline */
  .timeline {
    max-width: 800px;
    margin: 0 auto var(--spacing-xl);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .timeline-item {
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    transition: var(--transition-normal);
  }

  .timeline-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .timeline-marker {
    width: 48px;
    height: 48px;
    background-color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .event-number {
    color: var(--color-accent);
    font-weight: var(--font-weight-black);
    font-size: var(--font-size-sm);
  }

  .timeline-content {
    flex: 1;
  }

  .timeline-year-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    margin-bottom: 2px;
  }

  .timeline-year {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  .badge-online {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    color: var(--color-tertiary);
    background-color: var(--color-accent);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .timeline-title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    margin: 0;
  }

  .timeline-note {
    max-width: 800px;
    margin: 0 auto var(--spacing-xl);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    opacity: 0.75;
    text-align: center;
    line-height: var(--line-height-relaxed);
  }

  /* YouTube CTA */
  .youtube-cta {
    margin-top: var(--spacing-xl);
  }

  .youtube-card {
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: var(--spacing-xl);
    border-radius: var(--radius-md);
    max-width: 600px;
    margin: 0 auto;
  }

  .youtube-icon {
    width: 64px;
    height: 64px;
    background-color: var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    margin: 0 auto var(--spacing-md);
  }

  .youtube-card h3 {
    color: var(--color-tertiary);
    margin-bottom: var(--spacing-sm);
  }

  .youtube-card p {
    opacity: 0.95;
    margin-bottom: var(--spacing-md);
    line-height: var(--line-height-relaxed);
  }

  .youtube-card .btn-primary {
    background-color: var(--color-tertiary);
    color: var(--color-primary);
  }

  /* (cta styles moved to CtaSection.astro) */

  /* Responsive */
  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .about-stats {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }

    .stat-card {
      flex: 1;
      min-width: 150px;
    }
  }

  @media (max-width: 768px) {
    .event-meta {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .separator {
      display: none;
    }

    .featured-footer {
      flex-direction: column;
    }

    .featured-footer .btn-primary,
    .featured-footer .btn-secondary {
      width: 100%;
      text-align: center;
    }

    .timeline {
      grid-template-columns: 1fr;
    }

    .about-stats {
      flex-direction: column;
    }

    .stat-card {
      min-width: auto;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .cta-buttons .btn-primary,
    .cta-buttons .btn-secondary {
      width: 100%;
    }

    .youtube-card {
      padding: var(--spacing-lg);
    }
  }
</style>
