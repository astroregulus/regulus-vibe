---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import instructorsData from '../data/instructors.json';
const professores = instructorsData.instructors;
---

<BaseLayout title="Professores" description="Conheça os professores da Escola Regulus de Astrologia. Profissionais experientes dedicados ao ensino de qualidade em astrologia.">
  <Header currentPage="/professores" />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <h1>Nossos Professores</h1>
          <p class="hero-subtitle">
            Corpo docente qualificado com décadas de experiência no ensino e prática da astrologia.
          </p>
        </div>
      </div>
    </section>

    <!-- Founder Tribute Section -->
    <section class="section tribute">
      <div class="container">
        <div class="tribute-content">
          <div class="tribute-photo">
            <div class="tribute-initials">WF</div>
          </div>
          <div class="tribute-text">
            <span class="tribute-badge">Fundador</span>
            <h2>Prof. Waldyr Bonadei Fücher</h2>
            <p class="tribute-dates">18 de Agosto de 1926 — 19 de Fevereiro de 2012</p>
            <div class="tribute-separator"></div>
            <p class="tribute-description">
              Em <strong>1975</strong>, o Astrólogo e Professor Waldyr Bonadei Fücher fundou a Escola Regulus de Astrologia, 
              dando início a uma tradição de excelência no ensino astrológico que perdura até hoje. 
              Sua visão e dedicação transformaram a forma como a astrologia é ensinada no Brasil, 
              formando gerações de astrólogos profissionais.
            </p>
            <p class="tribute-quote">
              <em>"O céu ganhou mais uma estrela, e a terra se acostuma com a saudade."</em>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Instructors Grid Section -->
    <section class="section instructors">
      <div class="container">
        <h2 class="section-title text-center">Corpo Docente Atual</h2>
        <p class="section-subtitle text-center">
          Profissionais dedicados à formação de astrólogos qualificados, dando continuidade ao legado do fundador.
        </p>

        <div class="instructors-grid">
          {professores.map((professor) => (
            <article class="instructor-card">
              <div class="instructor-photo">
                <span class="instructor-initials">{professor.iniciais}</span>
              </div>
              <div class="instructor-info">
                <h3>{professor.nome}</h3>
                <span class="instructor-specialty">{professor.especialidade}</span>
                <p class="instructor-bio">{professor.bio}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta">
      <div class="container">
        <div class="cta-content text-center">
          <h2>Aprenda com os Melhores</h2>
          <p>
            Nossos professores estão prontos para guiá-lo em sua jornada de aprendizado astrológico.
            Conheça nossos cursos e comece sua formação.
          </p>
          <div class="cta-buttons">
            <a href="/cursos" class="btn-primary">Conheça Nossos Cursos</a>
            <a href="/contato" class="btn-secondary">Entre em Contato</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary) 70%, var(--color-accent) 100%);
    color: var(--color-tertiary);
    padding: var(--spacing-2xl) 0;
    text-align: center;
    position: relative;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-primary) 100%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-black);
    margin-bottom: var(--spacing-md);
    color: var(--color-tertiary);
  }

  .hero-subtitle {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    opacity: 0.95;
  }

  /* Tribute Section */
  .tribute {
    background-color: var(--color-tertiary);
    position: relative;
  }

  .tribute-content {
    display: flex;
    gap: var(--spacing-xl);
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .tribute-photo {
    flex-shrink: 0;
  }

  .tribute-initials {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-tertiary);
    font-size: 48px;
    font-weight: var(--font-weight-black);
    letter-spacing: 2px;
    border: 4px solid var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .tribute-text {
    flex: 1;
  }

  .tribute-badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-tertiary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
  }

  .tribute-text h2 {
    margin-bottom: var(--spacing-xs);
  }

  .tribute-dates {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    margin-bottom: var(--spacing-md);
  }

  .tribute-separator {
    width: 80px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: 2px;
    margin-bottom: var(--spacing-md);
  }

  .tribute-description {
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-md);
  }

  .tribute-quote {
    color: var(--color-primary);
    font-size: var(--font-size-lg);
    opacity: 0.9;
    border-left: 3px solid var(--color-accent);
    padding-left: var(--spacing-sm);
  }

  /* Instructors Section */
  .instructors {
    background-color: #f8f8f8;
  }

  .section-title {
    margin-bottom: var(--spacing-xs);
    display: inline-block;
    position: relative;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: 2px;
  }

  .section-subtitle {
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--spacing-lg);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .instructor-card {
    background-color: var(--color-tertiary);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-normal);
  }

  .instructor-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .instructor-photo {
    margin-bottom: var(--spacing-md);
  }

  .instructor-initials {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-tertiary);
    font-size: 32px;
    font-weight: var(--font-weight-black);
    letter-spacing: 1px;
    border: 3px solid var(--color-accent);
  }

  .instructor-info h3 {
    font-size: var(--font-size-h4);
    margin-bottom: var(--spacing-xs);
  }

  .instructor-specialty {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: 4px 12px;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
  }

  .instructor-bio {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
    opacity: 0.9;
  }

  /* CTA Section */
  .cta {
    background-color: var(--color-primary);
    color: var(--color-tertiary);
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta h2 {
    color: var(--color-tertiary);
    margin-bottom: var(--spacing-sm);
  }

  .cta p {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-lg);
    opacity: 0.95;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta .btn-primary {
    background-color: var(--color-tertiary);
    color: var(--color-primary);
  }

  .cta .btn-secondary {
    background-color: transparent;
    border: 2px solid var(--color-tertiary);
    color: var(--color-tertiary);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .instructors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-xl) 0;
    }

    .hero h1 {
      font-size: var(--font-size-h2);
    }

    .tribute-content {
      flex-direction: column;
      text-align: center;
    }

    .tribute-initials {
      width: 150px;
      height: 150px;
      font-size: 40px;
    }

    .tribute-separator {
      margin-left: auto;
      margin-right: auto;
    }

    .tribute-quote {
      border-left: none;
      padding-left: 0;
      border-top: 3px solid var(--color-accent);
      padding-top: var(--spacing-sm);
    }

    .instructors-grid {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .cta-buttons .btn-primary,
    .cta-buttons .btn-secondary {
      width: 100%;
    }
  }
</style>
