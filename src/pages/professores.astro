---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import CtaSection from '../components/CtaSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import instructorsData from '../data/instructors.json';
import coursesData from '../data/courses.json';

const professores = instructorsData.instructors;
const cursos = coursesData.courses;

// Create lookup map: slug → course
const cursosPorSlug = new Map(cursos.map(c => [c.slug, c]));
---

<BaseLayout title="Professores" description="Conheça os professores da Escola Regulus de Astrologia. Profissionais experientes dedicados ao ensino de qualidade em astrologia.">
  <Header currentPage="/professores" />
  
  <main>
    <HeroSection
      title="Nossos Professores"
      subtitle="Corpo docente qualificado com décadas de experiência no ensino e prática da astrologia."
      centered
    />

    <!-- Founder Tribute Section -->
    <section class="section tribute">
      <div class="container">
        <div class="tribute-content">
          <div class="tribute-photo">
            <div class="tribute-initials">WF</div>
          </div>
          <div class="tribute-text">
            <span class="tribute-badge">Fundador</span>
            <h2>Prof. Waldyr Bonadei Fücher</h2>
            <p class="tribute-dates">18 de Agosto de 1926 — 19 de Fevereiro de 2012</p>
            <div class="tribute-separator"></div>
            <p class="tribute-description">
              Em <strong>1975</strong>, o Astrólogo e Professor Waldyr Bonadei Fücher fundou a Escola Regulus de Astrologia, 
              dando início a uma tradição de excelência no ensino astrológico que perdura até hoje. 
              Sua visão e dedicação transformaram a forma como a astrologia é ensinada no Brasil, 
              formando gerações de astrólogos profissionais.
            </p>
            <p class="tribute-quote">
              <em>"O céu ganhou mais uma estrela, e a terra se acostuma com a saudade."</em>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Instructors Grid Section -->
    <section class="section instructors">
      <div class="container">
        <SectionHeader
          title="Corpo Docente Atual"
          subtitle="Profissionais dedicados à formação de astrólogos qualificados, dando continuidade ao legado do fundador."
          centered
        />

        <div class="instructors-grid">
          {professores.map((professor) => (
            <article class="instructor-card">
              <div class="instructor-photo">
                <span class="instructor-initials">{professor.iniciais}</span>
              </div>
              <div class="instructor-info">
                <h3>{professor.nome}</h3>
                <span class="instructor-specialty">{professor.especialidade}</span>
                <p class="instructor-bio">{professor.bio}</p>
                {professor.cursos && professor.cursos.length > 0 && (
                  <div class="instructor-courses">
                    <p class="instructor-courses-label">Ministra os cursos</p>
                    <ul class="instructor-courses-list">
                      {professor.cursos.map((slug) => {
                        const curso = cursosPorSlug.get(slug);
                        return curso ? (
                          <li>
                            <a href={`/cursos#${slug}`}>
                              <span class="course-dot" aria-hidden="true"></span>
                              {curso.title}
                              <span class="course-arrow" aria-hidden="true">→</span>
                            </a>
                          </li>
                        ) : null;
                      })}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaSection
      title="Aprenda com os Melhores"
      subtitle="Nossos professores estão prontos para guiá-lo em sua jornada de aprendizado astrológico. Conheça nossos cursos e comece sua formação."
      primaryBtn={{ label: 'Conheça Nossos Cursos', href: '/cursos' }}
      secondaryBtn={{ label: 'Entre em Contato', href: '/contato' }}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* (hero styles moved to HeroSection.astro) */

  /* Tribute Section */
  .tribute {
    background-color: var(--color-tertiary);
    position: relative;
  }

  .tribute-content {
    display: flex;
    gap: var(--spacing-xl);
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .tribute-photo {
    flex-shrink: 0;
  }

  .tribute-initials {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-tertiary);
    font-size: 48px;
    font-weight: var(--font-weight-black);
    letter-spacing: 2px;
    border: 4px solid var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .tribute-text {
    flex: 1;
  }

  .tribute-badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-tertiary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
  }

  .tribute-text h2 {
    margin-bottom: var(--spacing-xs);
  }

  .tribute-dates {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    margin-bottom: var(--spacing-md);
  }

  .tribute-separator {
    width: 80px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: var(--radius-sm);
    margin-bottom: var(--spacing-md);
  }

  .tribute-description {
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-md);
  }

  .tribute-quote {
    color: var(--color-primary);
    font-size: var(--font-size-lg);
    opacity: 0.9;
    border-left: 3px solid var(--color-accent);
    padding-left: var(--spacing-sm);
  }

  /* Instructors Section */
  .instructors {
    background-color: var(--color-surface);
  }

  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .instructor-card {
    background-color: var(--color-tertiary);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: var(--transition-normal);
  }

  .instructor-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .instructor-photo {
    margin-bottom: var(--spacing-md);
  }

  .instructor-initials {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-tertiary);
    font-size: 32px;
    font-weight: var(--font-weight-black);
    letter-spacing: 1px;
    border: 3px solid var(--color-accent);
  }

  .instructor-info h3 {
    font-size: var(--font-size-h4);
    margin-bottom: var(--spacing-xs);
  }

  .instructor-specialty {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
  }

  .instructor-bio {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
    opacity: 0.9;
  }

  /* Instructor courses block */
  .instructor-courses {
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border-light);
  }

  .instructor-courses-label {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
    margin-bottom: var(--spacing-xs);
  }

  .instructor-courses-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left;
  }

  .instructor-courses-list li a {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    text-decoration: none;
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    transition: background var(--transition-normal), color var(--transition-normal);
  }

  .instructor-courses-list li a:hover {
    background: var(--color-accent-alpha);
    color: var(--color-accent);
  }

  .course-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .course-arrow {
    margin-left: auto;
    color: var(--color-accent);
    font-size: var(--font-size-base);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .instructor-courses-list li a:hover .course-arrow {
    opacity: 1;
  }

  /* (cta styles moved to CtaSection.astro) */

  /* Responsive */
  @media (max-width: 1024px) {
    .instructors-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .tribute-content {
      flex-direction: column;
      text-align: center;
    }

    .tribute-initials {
      width: 150px;
      height: 150px;
      font-size: 40px;
    }

    .tribute-separator {
      margin-left: auto;
      margin-right: auto;
    }

    .tribute-quote {
      border-left: none;
      padding-left: 0;
      border-top: 3px solid var(--color-accent);
      padding-top: var(--spacing-sm);
    }

    .instructors-grid {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .cta-buttons .btn-primary,
    .cta-buttons .btn-secondary {
      width: 100%;
    }
  }
</style>
