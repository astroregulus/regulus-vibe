---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import CtaSection from '../components/CtaSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import coursesData from '../data/courses.json';
import instructorsData from '../data/instructors.json';

interface Turma {
  startDate: string;
  time: string;
  instructorId: string;
}

interface Course {
  title: string;
  description: string;
  level: string;
  duration: string;
  topics: string[];
  turmas: Turma[];
}

interface Instructor {
  id: string;
  nome: string;
  iniciais: string;
  especialidade: string;
  bio: string;
}

const courses = coursesData.courses as Course[];

const instructorMap = Object.fromEntries(
  instructorsData.instructors.map((i: Instructor) => [i.id, i])
);

const levelColors: Record<string, string> = {
  'Básico': '#2e7d32',
  'Intermediário': '#ed6c02',
  'Avançado': '#d32f2f',
};
---

<BaseLayout title="Cursos" description="Cursos de astrologia da Escola Regulus - Formação completa do básico ao avançado. Curso de Formação em Astrologia com 2 anos de duração.">
  <Header currentPage="/cursos" />
  
  <main>
    <HeroSection
      title="Cursos de Astrologia"
      subtitle="Formação completa em astrologia com professores experientes e metodologia comprovada há mais de 50 anos. Do básico ao avançado, desenvolvemos profissionais capacitados e certificados."
    />

    <!-- Main Course Section -->
    <section class="section main-course">
      <div class="container">
        <div class="main-course-card">
          <div class="main-course-badge">Curso Principal</div>
          <div class="main-course-content">
            <h2>Curso de Formação em Astrologia</h2>
            <p class="main-course-description">
              Programa completo de formação profissional em astrologia, desenvolvido 
              para transformar iniciantes em astrólogos qualificados. O curso abrange 
              desde os fundamentos até técnicas avançadas de interpretação e previsão.
            </p>
            
            <div class="main-course-features">
              <div class="feature">
                <span class="feature-icon">📚</span>
                <div class="feature-text">
                  <strong>Duração</strong>
                  <span>2 anos completos</span>
                </div>
              </div>
              <div class="feature">
                <span class="feature-icon">📊</span>
                <div class="feature-text">
                  <strong>Nível</strong>
                  <span>Básico ao Avançado</span>
                </div>
              </div>
              <div class="feature">
                <span class="feature-icon">✅</span>
                <div class="feature-text">
                  <strong>Certificação</strong>
                  <span>Conforme CBO</span>
                </div>
              </div>
            </div>

            <div class="main-course-details">
              <h3>O que você vai aprender:</h3>
              <ul>
                <li>Fundamentos da astrologia: signos, planetas, casas e aspectos</li>
                <li>Interpretação completa do mapa natal</li>
                <li>Técnicas de previsão: trânsitos, progressões e revoluções</li>
                <li>Sinastria e compatibilidade</li>
                <li>Astrologia horária e eletiva</li>
                <li>Ética e prática profissional</li>
              </ul>
            </div>

            <p class="cbo-note">
              <strong>Reconhecimento CBO:</strong> Nosso curso segue as diretrizes da 
              Classificação Brasileira de Ocupações (CBO 5168-05), preparando você para 
              atuar profissionalmente como astrólogo.
            </p>

            <a href="/contato" class="btn-primary">Inscreva-se Agora</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Courses Grid Section -->
    <section class="section courses">
      <div class="container">
        <SectionHeader
          title="Cursos de Especialização"
          subtitle="Aprofunde seus conhecimentos em áreas específicas da astrologia com nossos cursos de extensão e especialização."
          centered
        />
        
        <div class="courses-grid">
          {courses.map((course) => (
            <article class="course-card">
              <div class="course-card-header">
                <span class="course-level" style={`--level-color: ${levelColors[course.level]}`}>
                  {course.level}
                </span>
              </div>
              <div class="course-card-body">
                <h3>{course.title}</h3>
                <p>{course.description}</p>
                <div class="course-meta">
                  <span class="course-duration">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {course.duration}
                  </span>
                </div>
              </div>
              <div class="course-card-footer">
                <button
                  class="btn-secondary course-toggle"
                  aria-expanded="false"
                  data-course-toggle
                >
                  Saiba Mais
                </button>
              </div>

              <div class="course-details" aria-hidden="true">

                <div class="course-details-section">
                  <h4>Conteúdo do Curso</h4>
                  <ul class="course-topics">
                    {course.topics.map((topic: string) => (
                      <li>{topic}</li>
                    ))}
                  </ul>
                </div>

                <div class="course-details-section">
                  <h4>Próximas Turmas</h4>
                  {course.turmas.length > 0 ? (
                    <ul class="course-turmas">
                      {course.turmas.map((turma: Turma) => {
                        const instructor = instructorMap[turma.instructorId];
                        return (
                          <li class="turma-item">
                            <span class="turma-date">{turma.startDate}</span>
                            <span class="turma-time">{turma.time}</span>
                            {instructor && (
                              <span class="turma-instructor">{instructor.nome}</span>
                            )}
                          </li>
                        );
                      })}
                    </ul>
                  ) : (
                    <p class="no-turmas">Em breve. Entre em contato para ser avisado.</p>
                  )}
                </div>

                <a
                  href={`https://wa.me/5511999999999?text=${encodeURIComponent(`Olá! Tenho interesse no curso de ${course.title}.`)}`}
                  class="btn-whatsapp"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Envie uma mensagem
                </a>

              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaSection
      title="Pronto para Começar sua Jornada?"
      subtitle="Entre em contato conosco para saber mais sobre nossos cursos, horários das turmas e valores de investimento. Estamos prontos para ajudá-lo a trilhar o caminho das estrelas."
      primaryBtn={{ label: 'Fale Conosco', href: '/contato' }}
      secondaryBtn={{ label: 'WhatsApp', href: 'https://wa.me/5511999999999' }}
    />
  </main>

  <Footer />
</BaseLayout>

<style>
  /* (hero styles moved to HeroSection.astro) */

  /* Main Course Section */
  .main-course {
    background-color: var(--color-tertiary);
  }

  .main-course-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .main-course-badge {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    background-color: var(--color-accent);
    color: var(--color-tertiary);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
  }

  .main-course-content {
    padding: var(--spacing-lg);
  }

  .main-course-content h2 {
    font-size: var(--font-size-h2);
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
    position: relative;
    display: inline-block;
  }

  .main-course-content h2::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--spacing-xs));
    left: 0;
    width: 60px;
    height: 4px;
    background-color: var(--color-accent);
    border-radius: var(--radius-sm);
  }

  .main-course-description {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-lg);
    margin-top: var(--spacing-md);
  }

  .main-course-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-md);
    background-color: var(--color-tertiary);
    border-radius: var(--radius-md);
  }

  .feature {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .feature-icon {
    font-size: 28px;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
  }

  .feature-text strong {
    font-size: var(--font-size-sm);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .feature-text span {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
  }

  .main-course-details {
    margin-bottom: var(--spacing-lg);
  }

  .main-course-details h3 {
    font-size: var(--font-size-h4);
    margin-bottom: var(--spacing-sm);
    color: var(--color-primary);
  }

  .main-course-details ul {
    list-style: none;
    padding: 0;
  }

  .main-course-details li {
    padding: var(--spacing-xs) 0;
    padding-left: var(--spacing-md);
    position: relative;
  }

  .main-course-details li::before {
    content: '★';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--font-size-sm);
  }

  .cbo-note {
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: var(--spacing-md);
    border-radius: var(--radius-sm);
    margin-bottom: var(--spacing-lg);
    font-size: var(--font-size-sm);
  }

  .cbo-note strong {
    color: var(--color-accent);
  }

  /* Courses Grid Section */
  .courses {
    background-color: var(--color-tertiary);
    position: relative;
  }

  .courses::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-accent) 50%, var(--color-primary) 100%);
  }

  /* (section-title/subtitle styles moved to SectionHeader.astro) */

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  .course-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: var(--transition-normal);
  }

  .course-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .course-card-header {
    padding: var(--spacing-sm) var(--spacing-md);
    padding-bottom: 0;
  }

  .course-level {
    display: inline-block;
    background-color: var(--level-color);
    color: var(--color-tertiary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .course-card-body {
    padding: var(--spacing-md);
    flex: 1;
  }

  .course-card-body h3 {
    font-size: var(--font-size-h4);
    margin-bottom: var(--spacing-sm);
    color: var(--color-primary);
  }

  .course-card-body p {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    opacity: 0.9;
  }

  .course-meta {
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border-light);
  }

  .course-duration {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .course-duration svg {
    color: var(--color-accent);
  }

  .course-card-footer {
    padding: var(--spacing-md);
    padding-top: 0;
  }

  .course-card-footer .btn-secondary {
    width: 100%;
    text-align: center;
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    cursor: pointer;
    border: none;
    font-family: inherit;
    font-size: inherit;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-sm);
    transition: var(--transition-normal);
  }

  .course-card-footer .btn-secondary:hover {
    opacity: 0.85;
  }

  .course-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding: 0 var(--spacing-md);
    border-top: 0px solid var(--color-border-light);
  }

  .course-card.expanded .course-details {
    max-height: 600px;
    padding-bottom: var(--spacing-md);
    border-top-width: 1px;
  }

  .course-details-section {
    margin-top: var(--spacing-md);
  }

  .course-details-section h4 {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  .course-topics {
    list-style: none;
    padding: 0;
  }

  .course-topics li {
    font-size: var(--font-size-sm);
    padding: var(--spacing-xs) 0;
    padding-left: var(--spacing-md);
    position: relative;
    line-height: var(--line-height-relaxed);
  }

  .course-topics li::before {
    content: '★';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: var(--font-size-xs);
    top: calc(var(--spacing-xs) + 2px);
  }

  .course-turmas {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .turma-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-xs) var(--spacing-sm);
    align-items: center;
    font-size: var(--font-size-sm);
    padding: var(--spacing-sm);
    background-color: var(--color-tertiary);
    border-radius: var(--radius-sm);
  }

  .turma-date {
    font-weight: var(--font-weight-bold);
    color: var(--color-primary);
    grid-column: 1 / -1;
  }

  .turma-time {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .turma-instructor {
    color: var(--color-text);
    opacity: 0.8;
  }

  .no-turmas {
    font-size: var(--font-size-sm);
    opacity: 0.7;
    font-style: italic;
  }

  .btn-whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-md);
    background-color: #25d366;
    color: #fff;
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: var(--transition-normal);
  }

  .btn-whatsapp:hover {
    background-color: #1da851;
  }

  .course-card.expanded .course-toggle {
    opacity: 0.7;
  }

  /* (cta styles moved to CtaSection.astro) */

  /* Responsive */
  @media (max-width: 1024px) {
    .courses-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .main-course-features {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .main-course-features {
      grid-template-columns: 1fr;
    }

    .main-course-badge {
      position: static;
      display: inline-block;
      margin-bottom: var(--spacing-sm);
    }

    .courses-grid {
      grid-template-columns: 1fr;
    }

  }
</style>

<script>
  document.querySelectorAll('[data-course-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.course-card');
      if (!card) return;

      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const details = card.querySelector('.course-details');

      btn.setAttribute('aria-expanded', String(!isExpanded));
      card.classList.toggle('expanded', !isExpanded);

      if (details) {
        details.setAttribute('aria-hidden', String(isExpanded));
      }
    });
  });
</script>
