---
const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://youtube.com/@astrologiaregulus', label: 'YouTube', icon: 'youtube' },
  { href: 'https://www.facebook.com/regulus.astrologia', label: 'Facebook', icon: 'facebook' },
  { href: 'https://www.instagram.com/regulus.astrologia/', label: 'Instagram', icon: 'instagram' },
  { href: 'https://x.com/astroregulus', label: 'X (Twitter)', icon: 'x' },
  { href: 'https://www.linkedin.com/company/regulus-astrologia', label: 'LinkedIn', icon: 'linkedin' },
];

const quickLinks = [
  { href: '/cursos', label: 'Cursos' },
  { href: '/professores', label: 'Professores' },
  { href: '/encontros', label: 'Encontros' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/contato', label: 'Contato' },
];

const toolLinks = [
  { href: '/mapa', label: 'Mapa Astral' },
];

const bookstoreLinks = [
  { href: 'https://www.livrariadaregulus.com.br/categoria/astrologia-1/1', label: 'Astrologia' },
  { href: 'https://www.livrariadaregulus.com.br/categoria/tarot/1',        label: 'Tarô' },
  { href: 'https://www.livrariadaregulus.com.br/categoria/esoterismo/1',   label: 'Esoterismo' },
  { href: 'https://www.livrariadaregulus.com.br/categoria/ocultismo/1',    label: 'Ocultismo' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-col">
        <div class="footer-brand">
          <span class="footer-logo">REGULUS</span>
          <span class="footer-tagline">Escola de Astrologia</span>
        </div>
        <p class="footer-description">
          Desde 1975 formando astrólogos profissionais. 
          A melhor estrutura de ensino em astrologia do Brasil.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4 class="footer-title">Links Rápidos</h4>
        <ul class="footer-links">
          {quickLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Tools -->
      <div class="footer-col">
        <h4 class="footer-title">Ferramentas</h4>
        <ul class="footer-links">
          {toolLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Bookstore -->
      <div class="footer-col">
        <h4 class="footer-title">Livraria</h4>
        <ul class="footer-links">
          {bookstoreLinks.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <a
          href="https://www.livrariadaregulus.com.br"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-bookstore-cta"
        >
          Ver livraria completa ↗
        </a>
      </div>

      <!-- Contact Info -->
      <div class="footer-col">
        <h4 class="footer-title">Contato</h4>
        <address class="footer-contact">
          <p>Rua Estela, 515 cj.71 - E</p>
          <p>Vila Mariana - São Paulo, SP</p>
          <p>CEP: 04011-904</p>
          <p class="mt-2">
            <strong>Telefone:</strong> (11) 5549-2655
          </p>
          <p><small>(Atendimento: 14h às 19h)</small></p>
          <p class="mt-2">
            <strong>Email:</strong> 
            <a href="mailto:astrologia@regulus.com.br">astrologia@regulus.com.br</a>
          </p>
        </address>
      </div>

      <!-- Social Media -->
      <div class="footer-col">
        <h4 class="footer-title">Redes Sociais</h4>
        <div class="social-links">
          {socialLinks.map((social) => (
            <a 
              href={social.href} 
              target="_blank" 
              rel="noopener noreferrer"
              aria-label={social.label}
              class="social-link"
            >
              {social.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p>&copy; {currentYear} Regulus - Cursos, Assessoria Astrológica e Com. Ltda. Todos os direitos reservados.</p>
      <p class="footer-memorial">
        <em>"O céu ganhou mais uma estrela, e a terra se acostuma com a saudade."</em><br />
        Prof. Waldyr Bonadei Fücher - 18/08/1926 ~ 19/02/2012
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: var(--color-tertiary);
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    margin-top: auto;
  }

  /* layout delegated to global .container */

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    margin-bottom: var(--spacing-sm);
  }

  .footer-logo {
    font-size: var(--font-size-h3);
    font-weight: var(--font-weight-black);
    letter-spacing: 2px;
  }

  .footer-tagline {
    font-size: var(--font-size-xs);
    opacity: 0.9;
  }

  .footer-description {
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    opacity: 0.9;
  }

  .footer-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--spacing-sm);
    color: var(--color-tertiary);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: var(--spacing-xs);
  }

  .footer-links a {
    color: var(--color-tertiary);
    font-size: var(--font-size-sm);
    opacity: 0.9;
    transition: var(--transition-fast);
    font-weight: var(--font-weight-regular);
  }

  .footer-links a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .footer-bookstore-cta {
    display: inline-block;
    margin-top: var(--spacing-sm);
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    opacity: 1;
    transition: var(--transition-fast);
  }

  .footer-bookstore-cta:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .footer-contact {
    font-style: normal;
    font-size: var(--font-size-sm);
    line-height: var(--line-height-relaxed);
    opacity: 0.9;
  }

  .footer-contact a {
    color: var(--color-tertiary);
    font-weight: var(--font-weight-regular);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .social-link {
    color: var(--color-tertiary);
    font-size: var(--font-size-sm);
    opacity: 0.9;
    transition: var(--transition-fast);
    font-weight: var(--font-weight-regular);
  }

  .social-link:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .footer-bottom {
    border-top: 1px solid color-mix(in srgb, var(--color-tertiary) 20%, transparent);
    padding-top: var(--spacing-lg);
    text-align: center;
    font-size: var(--font-size-sm);
    opacity: 0.9;
  }

  .footer-memorial {
    margin-top: var(--spacing-md);
    font-size: var(--font-size-xs);
    opacity: 0.8;
  }

  @media (max-width: 1200px) {
    .footer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer > .container {
      padding: 0 var(--spacing-sm);
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .footer-col {
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-bookstore-cta {
      display: block;
    }

    .social-links {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--spacing-sm);
    }
  }
</style>
